# ── UNILIV Admin — Docker runtime env ────────────────────────────────────────
# Copy to .env.docker (gitignored) and fill in. Consumed by the `api` and
# `tools` containers (docker-compose.yml `env_file`).

# PostgreSQL on the HOST, reached from the container via the Docker host gateway.
# (Postgres is intentionally NOT containerised.) Use host.docker.internal — the
# compose file maps it to host-gateway. Make sure host Postgres listens on the
# docker bridge and pg_hba.conf allows the docker subnet (see DEPLOYMENT.md).
DATABASE_URL=postgresql://uniliv:CHANGE_ME@host.docker.internal:5432/uniliv

# JWT signing secret for access + refresh tokens (REQUIRED).
# Generate one:  openssl rand -hex 48
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Optional: transactional email (enables order emails; otherwise logged) ────
# NOTE: nodemailer is not bundled; to actually send mail, add it to the api
# image or run the api outside the slim bundle. Leave unset to disable.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=UNILIV <no-reply@unilivadmin.enaacreations.com>

# ── Optional: SMS OTP via Twilio (otherwise the OTP is logged in dev) ─────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# ── Optional: payments ────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
